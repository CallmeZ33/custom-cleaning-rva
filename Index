function addLog(msg, level = 'ok') {
  const entry = { time: new Date().toLocaleTimeString(), msg, level };
  CRM.logs.unshift(entry);
  CRM.logs = CRM.logs.slice(0, 100);
  storageSet('logs', CRM.logs);
  renderCRMNav();
}

function crmToast(msg, type = 'success') {
  const wrap = document.getElementById('crmToasts');
  const id = 'toast-' + Date.now();
  const div = document.createElement('div');
  div.className = `toast toast-${type}`;
  div.id = id;
  const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️';
  div.innerHTML = `<span>${icon}</span><span>${msg}</span>`;
  wrap.appendChild(div);
  setTimeout(() => { const el = document.getElementById(id); if (el) el.remove(); }, 4500);
}

function renderCRMPage() {
  const el = document.getElementById('crmPageContent');
  switch (CRM.page) {
    case 'dashboard':  el.innerHTML = renderDashboard();  break;
    case 'bookings':   el.innerHTML = renderBookings();   break;
    case 'clients':    el.innerHTML = renderClients();    break;
    case 'newsletter': el.innerHTML = renderNewsletter(); break;
    case 'calendar':   el.innerHTML = renderCalendar();   break;
    case 'sms':        el.innerHTML = renderSMS();        break;
    case 'logs':       el.innerHTML = renderLogs();       break;
