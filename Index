// ══════════════════════════════════════
async function callClaude(messages, mcpServers = [], systemPrompt = "You are a helpful assistant.") {
  const body = {
    model: "claude-sonnet-4-20250514",
    max_tokens: 1000,
    system: systemPrompt,
    messages
  };
  if (mcpServers.length) body.mcp_servers = mcpServers;
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });
  const data = await res.json();
  if (data.error) throw new Error(data.error.message);
  return data;
}

const SMS_GATEWAYS = {
  att:    '%s@txt.att.net', verizon: '%s@vtext.com',
  tmobile:'%s@tmomail.net', sprint:  '%s@messaging.sprintpcs.com', boost: '%s@sms.myboostmobile.com'
};
function smsEmail(phone, carrier) {
  const digits = phone.replace(/\D/g, '');
  return (SMS_GATEWAYS[carrier] || SMS_GATEWAYS.att).replace('%s', digits);
}

