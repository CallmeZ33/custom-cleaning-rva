  const name  = document.getElementById('nl-name').value.trim();
  if (!email) { crmToast('Email required.', 'error'); return; }
  if (CRM.subscribers.find(s => s.email === email)) { crmToast('Already subscribed.', 'error'); return; }
  CRM.subscribers.unshift({ email, name, dateAdded: new Date().toLocaleDateString(), source: 'Manual' });
  await storageSet('subscribers', CRM.subscribers);
  crmToast('Subscriber added!');
  addLog(`Subscriber added manually: ${email}`, 'ok');
  renderCRMNav();
  renderCRMPage();
}

async function removeSubscriber(idx) {
  if (!confirm('Remove this subscriber?')) return;
  const s = CRM.subscribers[idx];
  CRM.subscribers.splice(idx, 1);
  await storageSet('subscribers', CRM.subscribers);
  crmToast('Subscriber removed.', 'info');
  addLog(`Subscriber removed: ${s.email}`, 'warn');
  renderCRMNav();
  renderCRMPage();
}

async function sendNewsletter() {
  const subject = document.getElementById('nl-subject').value;
  const body    = document.getElementById('nl-body').value;
  if (!subject || !body) { crmToast('Subject and body required.', 'error'); return; }
  const btn = document.getElementById('sendNlBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Sending...'; }
  const resultEl = document.getElementById('nlResult');
  try {
    const prompt = `Send a newsletter email from Custom Cleaning RVA to all subscribers.\n\nSubscribers: ${CRM.subscribers.map(s=>s.email).join(', ')}\n\nSubject: ${subject}\n\nBody:\n${body}\n\nSend as a professional HTML email. Replace [First Name] with each subscriber's first name where possible.`;
    const data = await callClaude(
      [{role:'user',content:prompt}],
      [{type:'url',url:'https://gmail.mcp.claude.com/mcp',name:'gmail'}],
      'You are a newsletter assistant for Custom Cleaning RVA. Use Gmail to send bulk emails.'
    );
    const txt = data.content.filter(b=>b.type==='text').map(b=>b.text).join('\n');
    if (resultEl) resultEl.innerHTML = `<div style="padding:1rem;border-radius:8px;background:var(--green-l);color:var(--green);font-size:.85rem">✅ Newsletter sent to ${CRM.subscribers.length} subscribers!<br><small>${txt.slice(0,200)}</small></div>`;
    addLog(`💌 Newsletter sent to ${CRM.subscribers.length} subscribers: "${subject}"`, 'ok');
    crmToast(`Newsletter sent to ${CRM.subscribers.length} subscribers!`);
  } catch(e) {
    if (resultEl) resultEl.innerHTML = `<div style="padding:1rem;border-radius:8px;background:var(--red-l);color:var(--red);font-size:.85rem">❌ Failed: ${e.message}</div>`;
    addLog(`❌ Newsletter failed: ${e.message}`, 'err');
    crmToast('Newsletter failed. Check Gmail connection.', 'error');
  }
  if (btn) { btn.disabled = false; btn.innerHTML = `📧 Send to All ${CRM.subscribers.length} Subscribers`; }
}

// ══════════════════════════════════════
//  CALENDAR SYNC
// ══════════════════════════════════════
function renderCalendar() {
  const upcoming = CRM.bookings.filter(b => b.status === 'Confirmed' || b.status === 'Pending');
  return `
  <div class="crm-topbar"><div><div class="crm-topbar-title">🗓️ Google Calendar Sync</div><div class="crm-topbar-sub">Auto-add bookings to your Google Calendar</div></div></div>
  <div class="crm-content">
    <div class="card" style="margin-bottom:1rem">
      <div class="card-header"><div class="card-title">Add Booking to Calendar</div></div>
      <div class="card-body">
        <div class="form-grp" style="margin-bottom:.9rem">
          <label>Select Booking to Sync</label>
          <select id="cal-select">
            <option value="">— Choose a booking —</option>
            ${upcoming.map(b=>`<option value="${b.id}">${b.name} — ${b.service} — ${b.preferredDate} ${b.timeSlot||''}</option>`).join('')}
          </select>
          ${upcoming.length===0 ? '<div class="form-hint">No confirmed/pending bookings. Add some first.</div>' : ''}
        </div>
        <div id="calPreview"></div>
        <div style="margin-top:1rem">
          <button class="btn btn-p" id="calBtn" onclick="syncToCalendar()">📅 Add to Google Calendar</button>
        </div>
        <div id="calResult" style="margin-top:1rem"></div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title">📋 All Confirmed Bookings</div></div>
      <div class="table-wrap">
        ${upcoming.length===0 ? `<div class="empty-state"><div class="empty-icon">🗓️</div><h3>No upcoming bookings</h3></div>` : `
        <table>
          <thead><tr><th>Booking ID</th><th>Client</th><th>Service</th><th>Date</th><th>Time</th><th>Status</th></tr></thead>
          <tbody>${upcoming.map(b=>`
            <tr>
              <td><span style="font-family:monospace;font-size:.72rem;color:var(--teal)">${b.id}</span></td>
              <td><strong>${b.name}</strong></td><td>${b.service}</td>
              <td>${b.preferredDate}</td><td>${b.timeSlot||'—'}</td>
              <td>${statusBadge(b.status)}</td>
            </tr>`).join('')}
          </tbody>
        </table>`}
      </div>
    </div>
  </div>`;
}

async function syncToCalendar() {
  const id = document.getElementById('cal-select').value;
  if (!id) { crmToast('Please select a booking first.', 'error'); return; }
  const b = CRM.bookings.find(x => x.id === id);
  if (!b) return;
  const btn = document.getElementById('calBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Adding to Calendar...'; }
  const resultEl = document.getElementById('calResult');
  try {
    const prompt = `Add a Google Calendar event:\nTitle: 🧹 ${b.service} — ${b.name}\nDate: ${b.preferredDate}\nTime: ${b.timeSlot}\nLocation: ${b.address}\nClient Phone: ${b.phone}\nNotes: ${b.notes||'None'}\nEst. Price: $${b.price||'TBD'}\nDuration: 2 hours\nAdd a 24-hour reminder.`;
    const data = await callClaude(
      [{role:'user',content:prompt}],
      [{type:'url',url:'https://gcal.mcp.claude.com/mcp',name:'gcal'}],
      'You are a calendar assistant for Custom Cleaning RVA. Use Google Calendar to create events.'
    );
    const txt = data.content.filter(b=>b.type==='text').map(b=>b.text).join('\n');
    if (resultEl) resultEl.innerHTML = `<div style="padding:1rem;border-radius:8px;background:var(--green-l);color:var(--green);font-size:.85rem">✅ Calendar event created for ${b.name}!<br><small>${txt.slice(0,200)}</small></div>`;
    addLog(`📅 Calendar event created: ${b.name} on ${b.preferredDate}`, 'ok');
    crmToast(`Calendar event added for ${b.name}!`);
  } catch(e) {
    if (resultEl) resultEl.innerHTML = `<div style="padding:1rem;border-radius:8px;background:var(--red-l);color:var(--red);font-size:.85rem">❌ Calendar sync failed: ${e.message}</div>`;
    addLog(`❌ Calendar sync failed: ${e.message}`, 'err');
    crmToast('Calendar sync failed.', 'error');
  }
  if (btn) { btn.disabled = false; btn.innerHTML = '📅 Add to Google Calendar'; }
}

// ══════════════════════════════════════
//  SMS PAGE
// ══════════════════════════════════════
function renderSMS() {
  return `
  <div class="crm-topbar"><div><div class="crm-topbar-title">📱 Send SMS</div><div class="crm-topbar-sub">Send text messages to clients via Gmail SMS gateway</div></div></div>
  <div class="crm-content">
    <div class="info-box yellow" style="margin-bottom:1rem">
      <strong>ℹ️ How SMS Works:</strong> Messages are sent via email-to-SMS carrier gateways using your connected Gmail. Select the client's carrier below.
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title">Compose &amp; Send SMS</div></div>
      <div class="card-body">
        <div class="form-grid">
          <div class="form-grp">
            <label>Select Client</label>
            <select id="sms-to" onchange="updateSMSPreview()">
              <option value="">— Choose client —</option>
              ${CRM.clients.map(c=>`<option value="${c.id}">${c.name} — ${c.phone}</option>`).join('')}
            </select>
          </div>
          <div class="form-grp">
            <label>Client's Carrier</label>
            <select id="sms-carrier" onchange="updateSMSPreview()">
              <option value="att">AT&amp;T</option><option value="verizon">Verizon</option>
              <option value="tmobile">T-Mobile</option><option value="sprint">Sprint</option>
              <option value="boost">Boost Mobile</option>
            </select>
          </div>
          <div class="form-grp form-full">
            <label>Message Template</label>
            <select id="sms-type" onchange="updateSMSPreview()">
              <option value="confirmation">✅ Booking Confirmation</option>
              <option value="reminder">⏰ Appointment Reminder (Day Before)</option>
              <option value="complete">🧹 Job Complete — Thank You</option>
              <option value="review">⭐ Request a Google Review</option>
              <option value="custom">✏️ Custom Message</option>
            </select>
          </div>
          <div class="form-grp form-full">
            <label>Message Preview</label>
            <textarea id="sms-msg" rows="4"></textarea>
            <div class="form-hint" id="sms-char">0/160 characters</div>
          </div>
        </div>
        <div id="sms-gateway" class="sms-preview-box" style="display:none"></div>
        <div style="margin-top:1rem">
          <button class="btn btn-p" id="smsBtn" onclick="sendSMS()">📱 Send SMS via Gmail</button>
        </div>
        <div id="smsResult" style="margin-top:1rem"></div>
      </div>
    </div>
  </div>`;
}

function updateSMSPreview() {
  const toId    = document.getElementById('sms-to')?.value;
  const carrier = document.getElementById('sms-carrier')?.value || 'att';
  const type    = document.getElementById('sms-type')?.value || 'confirmation';
  const msgEl   = document.getElementById('sms-msg');
  const charEl  = document.getElementById('sms-char');
  const gwEl    = document.getElementById('sms-gateway');
  const client  = CRM.clients.find(c => c.id === toId);
  const fn = client ? client.name.split(' ')[0] : 'there';

  const templates = {
    confirmation: `Hi ${fn}! 👋 This is Custom Cleaning RVA confirming your upcoming cleaning appointment. Reply STOP to opt out. Questions? Call/text (804) 814-5491.`,
    reminder:     `Hi ${fn}! 🧹 Reminder: Your Custom Cleaning RVA appointment is TOMORROW. Our team will arrive at your scheduled time. See you then! — Custom Cleaning RVA`,
    complete:     `Hi ${fn}! ✨ Your home is sparkling clean! Hope you love it. If anything missed expectations, reply within 24 hrs — we'll make it right. Thank you! — Custom Cleaning RVA`,
    review:       `Hi ${fn}! We loved serving you 🌟 If you enjoyed your clean, would you mind leaving us a quick Google review? It helps us a ton! Thanks — Custom Cleaning RVA`,
    custom:       msgEl?.value || ''
  };

  if (type !== 'custom' && msgEl) {
    msgEl.value = templates[type] || '';
    msgEl.readOnly = true;
    msgEl.style.background = 'var(--gray-light)';
  } else if (msgEl) {
    msgEl.readOnly = false;
    msgEl.style.background = '#fff';
  }

  const msg = msgEl?.value || '';
  if (charEl) charEl.textContent = `${msg.length}/160 characters ${msg.length > 160 ? '⚠️ Will send as multiple SMS' : '✅ Single SMS'}`;

  if (client && gwEl) {
    const addr = smsEmail(client.phone, carrier);
    gwEl.style.display = 'block';
    gwEl.innerHTML = `<strong>SMS Gateway:</strong> ${addr}<br><span style="color:var(--gray)">Message will be delivered as SMS to ${client.phone}</span>`;
  } else if (gwEl) {
    gwEl.style.display = 'none';
  }
}

async function sendSMS() {
  const toId    = document.getElementById('sms-to')?.value;
  const carrier = document.getElementById('sms-carrier')?.value || 'att';
  const msg     = document.getElementById('sms-msg')?.value;
  const client  = CRM.clients.find(c => c.id === toId);
  if (!client) { crmToast('Select a client first.', 'error'); return; }
  if (!msg)    { crmToast('Message is empty.', 'error'); return; }

  const btn = document.getElementById('smsBtn');
  const resultEl = document.getElementById('smsResult');
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Sending...'; }

  const smsAddr = smsEmail(client.phone, carrier);
  try {
    const prompt = `Send an SMS to a client via email-to-SMS gateway.\n\nSend an email to: ${smsAddr}\nSubject: Custom Cleaning RVA\nBody: ${msg}\n\nThis email will be delivered as an SMS to the client's phone.`;
    const data = await callClaude(
      [{role:'user',content:prompt}],
      [{type:'url',url:'https://gmail.mcp.claude.com/mcp',name:'gmail'}],
      'You are a messaging assistant for Custom Cleaning RVA. Use Gmail to send emails.'
    );
    const txt = data.content.filter(b=>b.type==='text').map(b=>b.text).join('\n');
    if (resultEl) resultEl.innerHTML = `<div style="padding:1rem;border-radius:8px;background:var(--green-l);color:var(--green);font-size:.85rem">✅ SMS sent to ${client.name}!</div>`;
    addLog(`📱 SMS sent to ${client.name} (${client.phone}) via ${carrier.toUpperCase()}`, 'ok');
    crmToast(`SMS sent to ${client.name}!`);
  } catch(e) {
    if (resultEl) resultEl.innerHTML = `<div style="padding:1rem;border-radius:8px;background:var(--red-l);color:var(--red);font-size:.85rem">❌ SMS failed: ${e.message}</div>`;
    addLog(`❌ SMS failed: ${e.message}`, 'err');
    crmToast('SMS send failed. Check Gmail connection.', 'error');
  }
  if (btn) { btn.disabled = false; btn.innerHTML = '📱 Send SMS via Gmail'; }
}

