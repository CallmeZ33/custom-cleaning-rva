function renderLogs() {
  return `
  <div class="crm-topbar"><div><div class="crm-topbar-title">📋 Activity Logs</div><div class="crm-topbar-sub">All CRM activity tracked here</div></div>
    <div class="crm-topbar-actions"><button class="btn btn-o btn-sm" onclick="clearLogs()">Clear Logs</button></div>
  </div>
  <div class="crm-content">
    <div class="card">
      <div class="card-body" style="padding:1rem">
        ${CRM.logs.length === 0 ? `<div class="empty-state"><div class="empty-icon">📋</div><h3>No activity yet</h3><p>Actions like adding bookings and sending SMS will appear here.</p></div>` : `
        <div class="log-wrap">
          ${CRM.logs.map(l=>`<div class="log-entry"><span class="log-time">[${l.time}]</span> <span class="log-${l.level}">${l.msg}</span></div>`).join('')}
        </div>`}
      </div>
    </div>
  </div>`;
}

async function clearLogs() {
  if (!confirm('Clear all activity logs?')) return;
  CRM.logs = [];
  await storageSet('logs', []);
  renderCRMPage();
}

// ══════════════════════════════════════
//  UTILS
// ══════════════════════════════════════
function statusBadge(s) {
  const map = { Confirmed:'badge-green', Pending:'badge-yellow', Cancelled:'badge-red', Completed:'badge-blue', 'No-Show':'badge-gray' };
  return `<span class="badge ${map[s||'Pending']||'badge-gray'}">${s||'—'}</span>`;
}

function bindCRMEvents() {
  // Wire up SMS preview after render
  if (CRM.page === 'sms') {
    updateSMSPreview();
    const msgEl = document.getElementById('sms-msg');
    if (msgEl) msgEl.addEventListener('input', () => {
      const charEl = document.getElementById('sms-char');
      if (charEl) charEl.textContent = `${msgEl.value.length}/160 characters ${msgEl.value.length > 160 ? '⚠️ Will send as multiple SMS' : '✅ Single SMS'}`;
    });
  }
  // Wire up calendar preview
  if (CRM.page === 'calendar') {
    const sel = document.getElementById('cal-select');
    if (sel) sel.addEventListener('change', () => {
      const b = CRM.bookings.find(x => x.id === sel.value);
      const prev = document.getElementById('calPreview');
      if (b && prev) {
        prev.innerHTML = `<div style="background:var(--gray-light);border-radius:8px;padding:8px;padding:1rem;margin-top:.75rem;font-size:.85rem"><strong>📋 Event Preview:</strong><br><span style="color:var(--teal);font-weight:700">🧹 ${b.service} — ${b.name}</span><br>📅 ${b.preferredDate} at ${b.timeSlot||'TBD'} · 📍 ${b.address}<br>📞 ${b.phone}${b.email?' · ✉️ '+b.email:''}${b.notes?'<br>📝 '+b.notes:''}</div>`;
      } else if (prev) {
        prev.innerHTML = '';
      }
    });
  }
}
