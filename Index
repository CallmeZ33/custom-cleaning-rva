async function saveBookingModal(editId) {
  const name    = document.getElementById('m-name').value.trim();
  const phone   = document.getElementById('m-phone').value.trim();
  const address = document.getElementById('m-address').value.trim();
  const date    = document.getElementById('m-date').value;
  if (!name || !phone || !address || !date) { alert('Please fill in Name, Phone, Address, and Date.'); return; }
  const email     = document.getElementById('m-email').value.trim();
  const service   = document.getElementById('m-service').value;
  const timeSlot  = document.getElementById('m-time').value;
  const beds      = document.getElementById('m-beds').value;
  const baths     = document.getElementById('m-baths').value;
  const addOns    = document.getElementById('m-addon').value;
  const price     = document.getElementById('m-price').value;
  const status    = document.getElementById('m-status').value;
  const notes     = document.getElementById('m-notes').value.trim();
  const newsletter= document.getElementById('m-nl').checked;

  if (editId) {
    const idx = CRM.bookings.findIndex(b => b.id === editId);
    if (idx > -1) Object.assign(CRM.bookings[idx], {name,phone,email,address,service,preferredDate:date,timeSlot,beds,baths,addOns,price,status,notes,newsletter});
  } else {
    const booking = { id:'CCR-'+Date.now(), name, phone, email, address, service, preferredDate:date, timeSlot, beds, baths, addOns, price, status, notes, newsletter, dateBooked: new Date().toLocaleDateString() };
    CRM.bookings.unshift(booking);
    // Upsert client
    if (!CRM.clients.find(c => c.phone === phone)) {
      CRM.clients.unshift({ id:'CL-'+Date.now(), name, phone, email, address, since:booking.dateBooked, service, visits:1, newsletter });
      await storageSet('clients', CRM.clients);
    }
    // Newsletter
    if (newsletter && email && !CRM.subscribers.find(s => s.email === email)) {
      CRM.subscribers.unshift({ email, name: name.split(' ')[0], dateAdded: booking.dateBooked, source: 'CRM Booking' });
      await storageSet('subscribers', CRM.subscribers);
    }
  }
  await storageSet('bookings', CRM.bookings);
  addLog(`${editId ? 'Booking updated' : 'New booking added'}: ${name} — ${service}`, 'ok');
  crmToast(`Booking ${editId ? 'updated' : 'added'} for ${name}!`);
  closeBookingModal();
  renderCRMNav();
  renderCRMPage();
}

async function deleteBooking(id) {
  if (!confirm('Delete this booking?')) return;
  const b = CRM.bookings.find(x => x.id === id);
  CRM.bookings = CRM.bookings.filter(x => x.id !== id);
  await storageSet('bookings', CRM.bookings);
  if (b) addLog(`Booking deleted: ${b.name}`, 'warn');
  crmToast('Booking deleted.', 'info');
  renderCRMNav();
  renderCRMPage();
}

function editBookingStatus(id) {
  const b = CRM.bookings.find(x => x.id === id);
  if (!b) return;
  const s = prompt(`Change status for ${b.name}:\nConfirmed / Pending / Completed / Cancelled / No-Show`, b.status);
  if (s) quickStatus(id, s);
}

