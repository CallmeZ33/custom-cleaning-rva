// ══════════════════════════════════════
//  BOOKING FORM → SAVES TO CRM
// ══════════════════════════════════════
async function submitBooking() {
  const fname   = document.getElementById('b-fname').value.trim();
  const phone   = document.getElementById('b-phone').value.trim();
  const address = document.getElementById('b-address').value.trim();
  const service = document.getElementById('b-service').value;
  const date    = document.getElementById('b-date').value;
  if (!fname || !phone || !address || !service || !date) {
    alert('Please fill in all required fields (marked with *).'); return;
  }
  const email      = document.getElementById('b-email').value.trim();
  const timeSlot   = document.getElementById('b-time').value;
  const addOn      = document.getElementById('b-addon').value;
  const notes      = document.getElementById('b-notes').value.trim();
  const newsletter = document.getElementById('b-newsletter').checked;

  const booking = {
    id:         'CCR-' + Date.now(),
    name:       fname,
    phone,
    email,
    address,
    service,
    preferredDate: date,
    timeSlot,
    addOns:     addOn,
    notes,
    newsletter,
    status:     'Pending',
    price:      '',
    dateBooked: new Date().toLocaleDateString()
  };

  // Persist into CRM storage
  try {
    const existing = await storageGet('bookings') || [];
    existing.unshift(booking);
    await storageSet('bookings', existing);

    // Upsert client
    const clients = await storageGet('clients') || [];
    if (!clients.find(c => c.phone === phone)) {
      clients.unshift({ id:'CL-'+Date.now(), name:fname, phone, email, address, since:booking.dateBooked, service, visits:1, newsletter });
      await storageSet('clients', clients);
    }

    // Newsletter opt-in
    if (newsletter && email) {
      const subs = await storageGet('subscribers') || [];
      if (!subs.find(s => s.email === email)) {
        subs.unshift({ email, name: fname.split(' ')[0], dateAdded: booking.dateBooked, source: 'Website Booking' });
        await storageSet('subscribers', subs);
      }
    }

    // Log
    const logs = await storageGet('logs') || [];
    logs.unshift({ time: new Date().toLocaleTimeString(), msg: `🌐 Website booking: ${fname} — ${service} on ${date}`, level: 'ok' });
    await storageSet('logs', logs.slice(0, 100));
  } catch(e) { /* storage may not be available on all hosts */ }

  document.getElementById('bookingFormWrap').style.display = 'none';
  document.getElementById('bookingSuccess').classList.add('show');
  window.scrollTo({ top: document.getElementById('booking').offsetTop - 80, behavior: 'smooth' });
}

