function calcQuote() {
  const service = document.getElementById('q-service').value;
  const beds = parseInt(document.getElementById('q-beds').value) || 3;
  const baths = parseInt(document.getElementById('q-baths').value) || 2;
  const addon = parseInt(document.getElementById('q-addon').value) || 0;
  const result = document.getElementById('quoteResult');
  if (!service) { result.classList.remove('show'); return; }
  const p = prices[service];
  const total = p.base + (beds * p.bed) + (baths * p.bath) + addon;
  const low = Math.round(total * 0.95 / 5) * 5;
  const high = Math.round(total * 1.1 / 5) * 5;
  document.getElementById('quotePrice').textContent = `$${low} – $${high}`;
  result.classList.add('show');
}

